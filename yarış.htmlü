<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Yarış Oyunu</title>
    <style>
        body { background: #000; color: #fff; font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .game-box { background: #1a1a1a; padding: 30px; border-radius: 20px; text-align: center; width: 80%; max-width: 400px; }
        #hiz { font-size: 24px; color: #8ab4f8; margin: 20px; }
        button { padding: 15px 30px; font-size: 18px; cursor: pointer; border-radius: 10px; border: none; margin: 5px; }
        .gaz { background: #4caf50; }
        .turbo { background: #ff9800; }
        .back-btn { position: absolute; top: 15px; left: 15px; color: #8ab4f8; text-decoration: none; }
    </style>
</head>
<body>
    <a href="oyunlar.html" class="back-btn">← Geri</a>
    
    <div class="game-box">
        <h1>Yarış Pisti</h1>
        <div id="hiz">Hız: 0 km/s</div>
        <button class="gaz" onclick="gazla()">Gazla 🏎️</button>
        <button class="turbo" onclick="turboBas()">Turbo! 🚀</button>
        <p id="durum"></p>
    </div>

    <script>
        let hiz = 0;
        function gazla() {
            hiz += 10;
            guncelle();
        }
        function turboBas() {
            hiz += 50;
            document.getElementById('durum').innerText = "TURBO AKTİF!";
            setTimeout(() => { document.getElementById('durum').innerText = ""; }, 1000);
            guncelle();
        }
        function guncelle() {
            document.getElementById('hiz').innerText = "Hız: " + hiz + " km/s";
        }
    </script>
</body>
</html>
