<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Coğrafya Asistanı</title>
    <style>
        body { background: #0f172a; color: #f1f5f9; font-family: sans-serif; display: flex; justify-content: center; padding: 20px; }
        .container { width: 100%; max-width: 600px; background: #1e293b; padding: 20px; border-radius: 15px; }
        input { width: 100%; padding: 15px; border-radius: 8px; border: none; box-sizing: border-box; font-size: 16px; }
        #ekran { margin-top: 20px; padding: 20px; background: #0f172a; border-radius: 8px; min-height: 150px; line-height: 1.6; }
    </style>
</head>
<body>

<div class="container">
    <h2>Coğrafya Asistanı</h2>
    <input type="text" id="komut" placeholder="Coğrafi terim yaz ve Enter'a bas..." onkeyup="sorgula(event)">
    <div id="ekran">Sorgu bekleniyor...</div>
</div>

<script>
// Burası coğrafya verilerin için özel bölme
const veriler = [const veriler = [
    { anahtar: ["anahtar1"], bilgi: "Bilgi 1" },
    { anahtar: ["anahtar2"], bilgi: "Bilgi 2" },
    // 
    { anahtar: ["anahtarN"], bilgi: "Bilgi N" }
];
function sorgula(e) {
    if (e.key !== 'Enter') return;
    let girdi = document.getElementById('komut').value.toLowerCase();
    let ekran = document.getElementById('ekran');
    let bul = veriler.find(item => item.anahtar.some(a => girdi.includes(a)));
    ekran.innerHTML = bul ? `<h3>Sonuç:</h3><p>${bul.bilgi}</p>` : "Bu bilgi sistemde henüz kayıtlı değil.";
}
</script>
</body>
</html>
